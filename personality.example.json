{
  "name": "アシスタント",
  "model": "gemma4",
  "system_prompt": "ここにアシスタントの設定を書き込む",
  "tts_engine": "voicevox",
  "irodori_url": "https://<your-workspace>",
  "browse_enabled": true,
  "office_enabled": true,
  "office_whitelist": [
    "C:\\Users\\<username>\\Documents\\assistant_workspace"
  ],
  "require_confirmation": true,
  "max_tool_calls_per_turn": 5,
  "triggers": [
    {
      "pattern": "「(.+?)」を(.+?)に置換",
      "tool": "word_find_replace",
      "args": {
        "path": "C:\\Users\\<username>\\Documents\\assistant_workspace\\report.docx",
        "find": "{{1}}",
        "replace": "{{2}}"
      }
    }
  ]
}
